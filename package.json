{
  "name": "flappy-bird",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "An authentic Flappy Bird clone built with TypeScript and Vite.",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "esbuild test/smoke.ts --bundle --platform=node --format=esm | node --input-type=module",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
